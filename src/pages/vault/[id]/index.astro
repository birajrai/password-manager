---
import { db } from '../../../lib/db';
import { vaultEntries } from '../../../lib/schema';
import { eq } from 'drizzle-orm';
import { decryptDerivedKey, decryptVaultPassword, getSecretKey } from '../../../lib/crypto';

export const prerender = false;

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect('/login');
}

const id = Astro.params.id;
if (!id) {
  return Astro.redirect('/vault');
}

const entry = await db
  .select()
  .from(vaultEntries)
  .where(eq(vaultEntries.id, id))
  .limit(1);

if (!entry[0] || entry[0].userId !== session.userId) {
  return Astro.redirect('/vault');
}

const secretKey = getSecretKey();
const vaultKey = decryptDerivedKey(
  {
    ciphertext: session.encryptedKey,
    iv: session.encryptedKeyIv,
    tag: session.encryptedKeyTag,
  },
  secretKey
);

const decrypted = decryptVaultPassword(
  {
    ciphertext: entry[0].ciphertext,
    iv: entry[0].iv,
    tag: entry[0].tag,
  },
  vaultKey
);

const safeUrl = entry[0].url && (entry[0].url.startsWith('http://') || entry[0].url.startsWith('https://'))
  ? entry[0].url
  : null;
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{entry[0].title} - Vault</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <header class="navbar">
      <div class="navbar-inner">
        <h2 class="logo">Vault</h2>
        <nav class="flex gap">
          <a href={`/vault/${id}/edit`} class="btn btn-primary">
            <i data-lucide="pencil" class="icon-sm"></i> Edit
          </a>
          <a href="/vault" class="btn btn-secondary">
            <i data-lucide="arrow-left" class="icon-sm"></i> Back
          </a>
        </nav>
      </div>
    </header>

    <main class="container">
      <div class="card">
        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem">
          <i data-lucide="key-round" style="width:24px;height:24px;color:var(--text-muted)"></i>
          <h3 style="margin-bottom:0">{entry[0].title}</h3>
        </div>

        <div class="detail-row">
          <i data-lucide="globe" class="detail-icon"></i>
          <span class="label">URL</span>
          {safeUrl ? (
            <a href={safeUrl} target="_blank" rel="noopener noreferrer">
              {entry[0].url}
            </a>
          ) : entry[0].url ? (
            <span>{entry[0].url}</span>
          ) : (
            <span class="muted">—</span>
          )}
        </div>

        <div class="detail-row">
          <i data-lucide="user" class="detail-icon"></i>
          <span class="label">Username</span>
          <span>{entry[0].username || '—'}</span>
        </div>

        <div class="detail-row">
          <i data-lucide="lock" class="detail-icon"></i>
          <span class="label">Password</span>
          <div class="password-display">
            <span id="password-text">{decrypted}</span>
            <button
              id="copy-btn"
              class="btn btn-small btn-secondary"
              data-copy
            >
              <i data-lucide="copy" class="icon-sm"></i>
            </button>
          </div>
        </div>

        {entry[0].category && (
          <div class="detail-row">
            <i data-lucide="folder" class="detail-icon"></i>
            <span class="label">Category</span>
            <span class="badge">{entry[0].category}</span>
          </div>
        )}

        <div style="margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--border)">
          <form action={`/api/vault/delete/${id}`} method="POST" style="display:inline">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this entry?')">
              <i data-lucide="trash-2" class="icon-sm"></i> Delete
            </button>
          </form>
        </div>
      </div>
    </main>

    <script type="module">
      import { createIcons, Pencil, ArrowLeft, KeyRound, Globe, User, Lock, Copy, Folder, Trash2 } from 'lucide';
      const icons = { Pencil, ArrowLeft, KeyRound, Globe, User, Lock, Copy, Folder, Trash2 };
      createIcons({ icons });

      const copyBtn = document.getElementById('copy-btn');
      if (copyBtn) {
        copyBtn.addEventListener('click', async () => {
          const text = document.getElementById('password-text')?.textContent;
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            const original = copyBtn.innerHTML;
            copyBtn.innerHTML = 'Copied!';
            setTimeout(() => { copyBtn.innerHTML = original; createIcons({ icons }); }, 1500);
          } catch {
            copyBtn.textContent = 'Failed';
          }
        });
      }
    </script>
  </body>
</html>
