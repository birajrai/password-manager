---
import { db } from '../../../lib/db';
import { vaultEntries } from '../../../lib/schema';
import { eq } from 'drizzle-orm';
import { decryptDerivedKey, decryptVaultPassword } from '../../../lib/crypto';

export const prerender = false;

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect('/login');
}

const id = Astro.params.id;
if (!id) {
  return Astro.redirect('/vault');
}

const entry = await db
  .select()
  .from(vaultEntries)
  .where(eq(vaultEntries.id, id))
  .limit(1);

if (!entry[0] || entry[0].userId !== session.userId) {
  return Astro.redirect('/vault');
}

const secretKey = Buffer.from(process.env.ENCRYPTION_SECRET!, 'hex');
const vaultKey = decryptDerivedKey(
  {
    ciphertext: session.encryptedKey,
    iv: session.encryptedKeyIv,
    tag: session.encryptedKeyTag,
  },
  secretKey
);

const decrypted = decryptVaultPassword(
  {
    ciphertext: entry[0].ciphertext,
    iv: entry[0].iv,
    tag: entry[0].tag,
  },
  vaultKey
);

const error = Astro.url.searchParams.get('error');
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edit {entry[0].title} - Vault</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <header class="navbar">
      <div class="navbar-inner">
        <h2 class="logo">Vault</h2>
        <nav>
          <a href={`/vault/${id}`} class="btn btn-secondary">Cancel</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <div class="card">
        <h3>Edit entry</h3>

        {error && <div class="alert alert-error">{error}</div>}

        <form action={`/api/vault/update/${id}`} method="POST">
          <div class="field">
            <label for="title">Title</label>
            <input
              type="text"
              id="title"
              name="title"
              value={entry[0].title}
              required
            />
          </div>

          <div class="field">
            <label for="url">URL</label>
            <input
              type="url"
              id="url"
              name="url"
              value={entry[0].url ?? ''}
              placeholder="https://"
            />
          </div>

          <div class="field">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              value={entry[0].username ?? ''}
            />
          </div>

          <div class="field">
            <label for="password">Password</label>
            <div class="password-field">
              <input
                type="password"
                id="password"
                name="password"
                value={decrypted}
                required
              />
              <button type="button" class="btn-toggle" id="toggle-pw" data-toggle="password" aria-label="Toggle password visibility">
                <i data-lucide="eye" class="icon-sm"></i>
              </button>
            </div>
          </div>

          <div class="field">
            <label for="category">Category</label>
            <input
              type="text"
              id="category"
              name="category"
              value={entry[0].category ?? ''}
            />
          </div>

          <button type="submit" class="btn btn-primary btn-full">
            Save changes
          </button>
        </form>
      </div>
    </main>

    <script type="module">
      import { createIcons, Eye, EyeOff } from 'lucide';
      createIcons({ icons: { Eye, EyeOff } });

      const toggle = document.getElementById('toggle-pw');
      const input = document.getElementById('password');
      if (toggle && input) {
        toggle.addEventListener('click', () => {
          const hidden = input.type === 'password';
          input.type = hidden ? 'text' : 'password';
          toggle.innerHTML = hidden
            ? '<i data-lucide="eye-off" class="icon-sm"></i>'
            : '<i data-lucide="eye" class="icon-sm"></i>';
          createIcons();
        });
      }
    </script>
  </body>
</html>
