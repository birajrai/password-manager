---
import type { InferSelectModel } from 'drizzle-orm';
import { db } from '../../lib/db';
import { vaultEntries } from '../../lib/schema';
import { eq } from 'drizzle-orm';
import { decryptDerivedKey } from '../../lib/crypto';

export const prerender = false;

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect('/login');
}

const entries = await db
  .select()
  .from(vaultEntries)
  .where(eq(vaultEntries.userId, session.userId))
  .orderBy(vaultEntries.createdAt);
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Vault</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <header class="navbar">
      <div class="navbar-inner">
        <h2 class="logo">Vault</h2>
        <nav class="flex gap">
          <a href="/vault/new" class="btn btn-primary">
            <i data-lucide="plus" class="icon-sm"></i> Add
          </a>
          <form action="/api/logout" method="POST" style="display:inline">
            <button type="submit" class="btn btn-secondary">
              <i data-lucide="log-out" class="icon-sm"></i> Logout
            </button>
          </form>
        </nav>
      </div>
    </header>

    <main class="container">
      {entries.length === 0 ? (
        <div class="empty-state">
          <i data-lucide="key-round" style="width:40px;height:40px;color:var(--text-muted);margin-bottom:0.75rem"></i>
          <h3>No entries yet</h3>
          <p class="muted">Add your first password entry</p>
          <a href="/vault/new" class="btn btn-primary" style="margin-top:1.25rem">
            <i data-lucide="plus" class="icon-sm"></i> Add entry
          </a>
        </div>
      ) : (
        <div class="entry-list">
          {entries.map((entry) => (
            <a href={`/vault/${entry.id}`} class="entry-card">
              <div style="display:flex;align-items:center;gap:0.75rem">
                <i data-lucide="key-round" style="width:18px;height:18px;color:var(--text-muted);flex-shrink:0"></i>
                <div class="entry-info">
                  <strong>{entry.title}</strong>
                  {entry.url && <span class="muted">{entry.url}</span>}
                </div>
              </div>
              <div class="entry-meta">
                {entry.category && (
                  <span class="badge">{entry.category}</span>
                )}
                <span class="muted">{entry.username}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </main>

    <script type="module">
      import { createIcons, Plus, LogOut, KeyRound } from 'lucide';
      createIcons({ icons: { Plus, LogOut, KeyRound } });
    </script>
  </body>
</html>
