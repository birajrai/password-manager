---
export const prerender = false;

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect('/login');
}

const error = Astro.url.searchParams.get('error');
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>New entry - Vault</title>
    <link rel="stylesheet" href="/styles/app.css" />
  </head>
  <body>
    <header class="navbar">
      <div class="navbar-inner">
        <h2 class="logo">Vault</h2>
        <nav>
          <a href="/vault" class="btn btn-secondary">Back</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <div class="card">
        <h3>New entry</h3>

        {error && <div class="alert alert-error">{error}</div>}

        <form action="/api/vault/create" method="POST">
          <div class="field">
            <label for="title">Title</label>
            <input type="text" id="title" name="title" required />
          </div>

          <div class="field">
            <label for="url">URL</label>
            <input type="url" id="url" name="url" placeholder="https://" />
          </div>

          <div class="field">
            <label for="username">Username</label>
            <input type="text" id="username" name="username" />
          </div>

          <div class="field">
            <label for="password">Password</label>
            <div class="password-field">
              <input type="password" id="password" name="password" required />
              <button type="button" class="btn-toggle" id="toggle-pw" data-toggle="password" aria-label="Toggle password visibility">
                <i data-lucide="eye" class="icon-sm"></i>
              </button>
            </div>
          </div>

          <div class="field">
            <label for="category">Category</label>
            <input type="text" id="category" name="category" />
          </div>

          <button type="submit" class="btn btn-primary btn-full">
            Save
          </button>
        </form>
      </div>
    </main>

    <script type="module">
      import { createIcons, Eye, EyeOff } from 'lucide';
      createIcons({ icons: { Eye, EyeOff } });

      const toggle = document.getElementById('toggle-pw');
      const input = document.getElementById('password');
      if (toggle && input) {
        toggle.addEventListener('click', () => {
          const hidden = input.type === 'password';
          input.type = hidden ? 'text' : 'password';
          toggle.innerHTML = hidden
            ? '<i data-lucide="eye-off" class="icon-sm"></i>'
            : '<i data-lucide="eye" class="icon-sm"></i>';
          createIcons();
        });
      }
    </script>
  </body>
</html>
